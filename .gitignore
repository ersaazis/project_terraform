# Local terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version 
# control as they are data based. For more information, see:
# https://www.terraform.io/docs/language/values/variables.html#variable-definitions-files-tfvars
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include lock file for version pinning (standard practice)
# .terraform.lock.hcl

# Include .terraformrc or terraform.rc in case of special provider locations
.terraformrc
terraform.rc

# AWS CLI installation files
awscliv2.zip
aws/
